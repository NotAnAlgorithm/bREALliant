# E2E test environment — points the app at the LOCAL Supabase Docker stack.
# Loaded by Vite when running in `test` mode (`npm run dev:e2e`, used by Playwright).
# This file is intentionally committed: it holds only the public local anon key.

VITE_SUPABASE_URL=http://127.0.0.1:54321

# Standard supabase-cli local "demo" anon key. If `supabase status` reports a
# different "anon key" for your machine, replace the value below with that one.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
