# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional — for `npm run db:push` (Supabase CLI)
# SUPABASE_ACCESS_TOKEN=           # from `npx supabase login`
# SUPABASE_DB_PASSWORD=            # Database password (Settings → Database)
# SUPABASE_DB_URL=                 # Transaction pooler URI (Connect → Transaction pooler)

# Legacy name also supported:
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — reusable cloud test user for `npm run test-user:seed` / `test-user:reset`
# TEST_USER_EMAIL=tester@example.com
# TEST_USER_USERNAME=admin
# TEST_USER_PASSWORD=BrealTest!2026
